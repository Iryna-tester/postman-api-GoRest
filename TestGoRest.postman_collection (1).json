  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "requests": {},
        "exec": [
          "// Generate random user profile and set collection variables",
          "(function(){",
          "    function randInt(min,max){return Math.floor(Math.random()*(max-min+1))+min}",
          "    function randomName(){const first=['Alex','Sam','Jordan','Taylor','Casey','Riley','Morgan','Jamie','Chris','Pat'];const last=['Smith','Johnson','Lee','Brown','Jones','Garcia','Miller','Davis'];return first[randInt(0,first.length-1)]+' '+last[randInt(0,last.length-1)];}",
          "    function randomEmail(name){const domains=['example.com','mail.com','test.org'];const clean=name.toLowerCase().replace(/[^a-z]/g,'');return clean+randInt(10,99)+'@'+domains[randInt(0,domains.length-1)];}",
          "    function randomPhone(){return '+1-'+(100+randInt(0,899))+'-'+(100+randInt(0,899))+'-'+(1000+randInt(0,8999));}",
          "    const name=randomName();",
          "    const email=randomEmail(name);",
          "    const phone=randomPhone();",
          "    const profile={name:name,email:email,phone:phone};",
          "    pm.collectionVariables.set('userProfile', JSON.stringify(profile));",
          "    pm.collectionVariables.set('userEmail', email);",
          "    pm.collectionVariables.set('userName', name);",
          "    pm.collectionVariables.set('userPhone', phone);",
          "})();"
